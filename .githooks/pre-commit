#!/usr/bin/env bash
# Mirror the blocking checks in IronMUD-public's CI so commits here won't
# fail there after `just publish-ironmud-public`.

# Run cargo fmt --check first (fastest gate, exact mirror of public CI).
# Uses the pinned toolchain's rustfmt + rustfmt.toml (max_width = 120).
echo "Running cargo fmt --all -- --check..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
  echo ""
  echo "Formatting check failed. Commit aborted."
  echo "Run 'cargo fmt --all' to fix, then re-stage and commit."
  exit 1
fi

# Run cargo audit if installed, fail commit on vulnerabilities.
if ! command -v cargo-audit &>/dev/null; then
  echo "cargo-audit not installed. Install with: cargo install cargo-audit"
  echo "Skipping audit check."
else
  cargo audit
fi

# Run tests, fail commit if any test fails
echo "Running cargo test..."
cargo test
if [ $? -ne 0 ]; then
  echo "Tests failed. Commit aborted."
  exit 1
fi
