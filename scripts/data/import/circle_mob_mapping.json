    "WIMPY":        { "action": "set_flag", "ironmud_flag": "cowardly" },
    "AGGR_EVIL":    { "action": "warn", "message": "alignment-conditional aggression not modeled (no alignment system)." },
    "AGGR_GOOD":    { "action": "warn", "message": "alignment-conditional aggression not modeled (no alignment system)." },
    "AGGR_NEUTRAL": { "action": "warn", "message": "alignment-conditional aggression not modeled (no alignment system)." },
    "MEMORY":       { "action": "set_flag", "ironmud_flag": "memory" },
    "HELPER":       { "action": "set_flag", "ironmud_flag": "helper" },
    "NOCHARM":      { "action": "warn", "message": "MOB_NOCHARM not modeled." },
    "NOSUMMON":     { "action": "warn", "message": "MOB_NOSUMMON not modeled." },
    "NOSLEEP":      { "action": "set_flag", "ironmud_flag": "no_sleep" },
