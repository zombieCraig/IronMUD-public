{
  "_comment": "Default CircleMUD -> IronMUD object mapping. APPLY_* affects now route through the unified ItemAffect/ActiveBuff lane (see plans/let-s-plan-out-a-zesty-dawn.md). Saving throws map onto the same single-roll resistance equation used for damage: SAVING_PARA/PETRI -> status_resistance vs 'sleep', SAVING_ROD/SPELL -> status_resistance vs '*' (wildcard), SAVING_BREATH -> typed damage_resistance split across fire/cold/lightning/acid. Conversion rates (5%/pt for status, 3%/pt for breath quad) are heuristic; tune in this file. AFF_POISON on items maps to a permanent poison DoT (cursed-amulet idiom). See docs/import-guide.md.",
  "extra_flag_actions": {
    "GLOW":         { "action": "set_flag", "ironmud_flag": "glow" },
    "HUM":          { "action": "set_flag", "ironmud_flag": "hum" },
    "INVISIBLE":    { "action": "set_flag", "ironmud_flag": "invisible" },
    "NODROP":       { "action": "set_flag", "ironmud_flag": "no_drop" },
    "NOSELL":       { "action": "set_flag", "ironmud_flag": "no_sell" },
    "NORENT":       { "action": "drop", "info": "no rent system" },
    "NODONATE":     { "action": "set_flag", "ironmud_flag": "no_donate" },
    "NOINVIS":      { "action": "warn", "message": "ITEM_NOINVIS (cannot be made invisible) not modeled." },
    "MAGIC":        { "action": "set_flag", "ironmud_flag": "magical" },
    "BLESS":        { "action": "warn", "message": "ITEM_BLESS not modeled (no alignment/blessing system)." },
    "ANTI_GOOD":    { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_EVIL":    { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_NEUTRAL": { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_MAGE":    { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_CLERIC":  { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_THIEF":   { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_WARRIOR": { "action": "warn", "message": "class-restricted use not modeled." }
  },
  "apply_actions": {
    "STR":           { "action": "add_item_affect", "effect_type": "strength_boost",     "magnitude_from": "value" },
    "DEX":           { "action": "add_item_affect", "effect_type": "dexterity_boost",    "magnitude_from": "value" },
    "CON":           { "action": "add_item_affect", "effect_type": "constitution_boost", "magnitude_from": "value" },
    "INT":           { "action": "add_item_affect", "effect_type": "intelligence_boost", "magnitude_from": "value" },
    "WIS":           { "action": "add_item_affect", "effect_type": "wisdom_boost",       "magnitude_from": "value" },
    "CHA":           { "action": "add_item_affect", "effect_type": "charisma_boost",     "magnitude_from": "value" },
    "ARMOR":         { "action": "set_armor_class" },
    "HITROLL":       { "action": "add_item_affect", "effect_type": "hit_bonus",          "magnitude_from": "value" },
    "DAMROLL":       { "action": "add_item_affect", "effect_type": "damage_bonus",       "magnitude_from": "value" },
    "MAXHIT":        { "action": "add_item_affect", "effect_type": "max_hp_bonus",       "magnitude_from": "value" },
    "MAXMANA":       { "action": "add_item_affect", "effect_type": "max_mana_bonus",     "magnitude_from": "value" },
    "MAXMOVE":       { "action": "warn", "message": "APPLY_MAXMOVE not modeled (no move stat)." },
    "AGE":           { "action": "drop", "info": "no aging system on player characters" },
    "CHAR_WEIGHT":   { "action": "drop" },
    "CHAR_HEIGHT":   { "action": "drop" },
    "SAVING_PARA":   { "action": "add_item_affect", "effect_type": "status_resistance", "vs_effect": "sleep", "magnitude_scale": 5 },
    "SAVING_PETRI":  { "action": "add_item_affect", "effect_type": "status_resistance", "vs_effect": "sleep", "magnitude_scale": 5 },
    "SAVING_ROD":    { "action": "add_item_affect", "effect_type": "status_resistance", "vs_effect": "*",     "magnitude_scale": 5 },
    "SAVING_SPELL":  { "action": "add_item_affect", "effect_type": "status_resistance", "vs_effect": "*",     "magnitude_scale": 5 },
    "SAVING_BREATH": { "action": "add_item_affect_multi", "entries": [
      { "effect_type": "damage_resistance", "damage_type": "fire",      "magnitude_scale": 3 },
      { "effect_type": "damage_resistance", "damage_type": "cold",      "magnitude_scale": 3 },
      { "effect_type": "damage_resistance", "damage_type": "lightning", "magnitude_scale": 3 },
      { "effect_type": "damage_resistance", "damage_type": "acid",      "magnitude_scale": 3 }
    ]},
    "CLASS":         { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "LEVEL":         { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "GOLD":          { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "EXP":           { "action": "drop", "info": "no XP system" }
  },
  "aff_actions": {
    "_comment": "CircleMUD AFF_* bits on objects emulate worn-while-equipped affect stamps. Stock Circle ITEM_OBJ doesn't have a separate AFF_ field; these mappings serve any importer that surfaces AFF-tagged item affects. AFF_POISON applies the Poison DoT to the wearer (cursed-amulet idiom).",
    "INVISIBLE":     { "action": "add_item_affect", "effect_type": "invisibility" },
    "DETECT_INVIS":  { "action": "add_item_affect", "effect_type": "detect_invisible" },
    "DETECT_MAGIC":  { "action": "add_item_affect", "effect_type": "detect_magic" },
    "SENSE_LIFE":    { "action": "add_item_affect", "effect_type": "detect_invisible" },
    "INFRAVISION":   { "action": "add_item_affect", "effect_type": "night_vision" },
    "SANCTUARY":     { "action": "add_item_affect", "effect_type": "damage_reduction", "magnitude": 50 },
    "BLIND":         { "action": "add_item_affect", "effect_type": "blind",  "magnitude": 50 },
    "SLEEP":         { "action": "add_item_affect", "effect_type": "sleep" },
    "CURSE":         { "action": "add_item_affect", "effect_type": "curse",  "magnitude": 10 },
    "POISON":        { "action": "add_item_affect", "effect_type": "poison", "magnitude": 1  },
    "WATERWALK":     { "action": "add_item_affect", "effect_type": "water_breathing" },
    "PROTECT_GOOD":  { "action": "warn", "message": "AFF_PROTECT_GOOD not modeled (no alignment system)." },
    "PROTECT_EVIL":  { "action": "warn", "message": "AFF_PROTECT_EVIL not modeled (no alignment system)." }
  }
}
