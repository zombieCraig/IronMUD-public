{
  "_comment": "Default CircleMUD -> IronMUD object mapping. ITEM_* extra-bits with no IronMUD analogue surface as 'warn' so unsupported behavior shows in the dry-run report. APPLY_* affect entries map cleanly for STR/DEX/CON/INT/WIS/CHA + ARMOR; the rest warn until the matching IronMUD systems exist. Edit to suppress noise (use 'drop') or wire new translations once IronMUD systems exist. See docs/import-guide.md.",
  "extra_flag_actions": {
    "GLOW":         { "action": "set_flag", "ironmud_flag": "glow" },
    "HUM":          { "action": "set_flag", "ironmud_flag": "hum" },
    "INVISIBLE":    { "action": "set_flag", "ironmud_flag": "invisible" },
    "NODROP":       { "action": "set_flag", "ironmud_flag": "no_drop" },
    "NOSELL":       { "action": "set_flag", "ironmud_flag": "no_sell" },
    "NORENT":       { "action": "drop", "info": "no rent system" },
    "NODONATE":     { "action": "drop", "info": "no donation system" },
    "NOINVIS":      { "action": "warn", "message": "ITEM_NOINVIS (cannot be made invisible) not modeled." },
    "MAGIC":        { "action": "set_flag", "ironmud_flag": "magical" },
    "BLESS":        { "action": "warn", "message": "ITEM_BLESS not modeled (no alignment/blessing system)." },
    "ANTI_GOOD":    { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_EVIL":    { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_NEUTRAL": { "action": "warn", "message": "alignment-restricted use not modeled (no alignment system)." },
    "ANTI_MAGE":    { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_CLERIC":  { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_THIEF":   { "action": "warn", "message": "class-restricted use not modeled." },
    "ANTI_WARRIOR": { "action": "warn", "message": "class-restricted use not modeled." }
  },
  "apply_actions": {
    "STR":           { "action": "set_stat", "ironmud_stat": "stat_str" },
    "DEX":           { "action": "set_stat", "ironmud_stat": "stat_dex" },
    "CON":           { "action": "set_stat", "ironmud_stat": "stat_con" },
    "INT":           { "action": "set_stat", "ironmud_stat": "stat_int" },
    "WIS":           { "action": "set_stat", "ironmud_stat": "stat_wis" },
    "CHA":           { "action": "set_stat", "ironmud_stat": "stat_cha" },
    "ARMOR":         { "action": "set_armor_class" },
    "HITROLL":       { "action": "set_hit_bonus" },
    "DAMROLL":       { "action": "set_damage_bonus" },
    "MAXHIT":        { "action": "warn", "message": "APPLY_MAXHIT bonus not modeled at item level." },
    "MAXMANA":       { "action": "warn", "message": "APPLY_MAXMANA bonus not modeled at item level." },
    "MAXMOVE":       { "action": "warn", "message": "APPLY_MAXMOVE not modeled (no move stat)." },
    "AGE":           { "action": "drop", "info": "no aging system on player characters" },
    "CHAR_WEIGHT":   { "action": "drop" },
    "CHAR_HEIGHT":   { "action": "drop" },
    "SAVING_PARA":   { "action": "warn", "message": "saving throws not modeled." },
    "SAVING_ROD":    { "action": "warn", "message": "saving throws not modeled." },
    "SAVING_PETRI":  { "action": "warn", "message": "saving throws not modeled." },
    "SAVING_BREATH": { "action": "warn", "message": "saving throws not modeled." },
    "SAVING_SPELL":  { "action": "warn", "message": "saving throws not modeled." },
    "CLASS":         { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "LEVEL":         { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "GOLD":          { "action": "drop", "info": "unimplemented in stock CircleMUD" },
    "EXP":           { "action": "drop", "info": "no XP system" }
  }
}
