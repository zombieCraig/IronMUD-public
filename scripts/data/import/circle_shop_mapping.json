    "STAFF":         { "action": "set_flag", "ironmud_flag": "misc" },
    "WEAPON":        { "action": "set_flag", "ironmud_flag": "weapon" },
    "FIRE WEAPON":   { "action": "warn", "message": "FIRE WEAPON unimplemented in stock CircleMUD; shop won't accept this type." },
    "MISSILE":       { "action": "warn", "message": "MISSILE unimplemented in stock CircleMUD; shop won't accept this type." },
    "TREASURE":      { "action": "set_flag", "ironmud_flag": "misc" },
    "ARMOR":         { "action": "set_flag", "ironmud_flag": "armor" },
    "POTION":        { "action": "set_flag", "ironmud_flag": "liquid_container" },
    "WORN":          { "action": "set_flag", "ironmud_flag": "misc" },
    "OTHER":         { "action": "set_flag", "ironmud_flag": "misc" },
    "TRASH":         { "action": "set_flag", "ironmud_flag": "misc" },
    "TRAP":          { "action": "warn", "message": "TRAP unimplemented in stock CircleMUD; shop won't accept this type." },
    "CONTAINER":     { "action": "set_flag", "ironmud_flag": "container" },
    "NOTE":          { "action": "set_flag", "ironmud_flag": "misc" },
    "LIQ CONTAINER": { "action": "set_flag", "ironmud_flag": "liquid_container" },
