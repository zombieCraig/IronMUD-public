    "FOOD":          { "action": "set_flag", "ironmud_flag": "food" },
    "MONEY":         { "action": "set_flag", "ironmud_flag": "gold" },
    "PEN":           { "action": "set_flag", "ironmud_flag": "misc" },
    "BOAT":          { "action": "set_flag", "ironmud_flag": "misc" },
    "FOUNTAIN":      { "action": "set_flag", "ironmud_flag": "liquid_container" }
